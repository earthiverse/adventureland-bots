{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": true,
    "lib": ["ES2023"],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "declaration": false,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "stripInternal": true,
    "target": "es2023",
    "types": ["bun", "node"]
  },
  "include": ["src/**/*.ts"]
}
