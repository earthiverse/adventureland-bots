{
  "extends": "@total-typescript/tsconfig/tsc/no-dom/library",
  "compilerOptions": {
    "incremental": true,
    "lib": ["ES2025"],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "noEmit": true,
    "target": "es2025",
    "types": ["bun", "node"]
  },
  "include": ["config/**/*.ts", "src/**/*.ts", "types/**/*.ts", "tests/**/*.ts", "*.config.js"]
}
